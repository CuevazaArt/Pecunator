# Pecunator Configuration Template
# Copy this file to .env or set these variables in your environment before running the engine.

# --- API Server ---
# The host IP the backend will bind to (default: 127.0.0.1)
PECUNATOR_API_HOST=127.0.0.1
# The port the backend will listen on (default: 8000)
PECUNATOR_API_PORT=8000
# Disable API authentication in staging (DANGER: DO NOT USE IN PRODUCTION)
# PECUNATOR_API_AUTH_DISABLED=1

# --- Data & Logging ---
# Absolute path to the runtime data directory (default: runtime/data)
# PECUNATOR_DATA_DIR=/var/lib/pecunator/data
# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
PECUNATOR_LOG_LEVEL=INFO

# --- Telemetry & Alerts ---
# Telegram bot token for critical alerts (e.g. orphan detected, fuse tripped)
# PECUNATOR_ALERT_TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Telegram chat ID where alerts will be sent
# PECUNATOR_ALERT_TELEGRAM_CHAT_ID=-1001234567890

# --- Binance API (Fallback) ---
# Most credentials should be managed via the desktop vault, but you can set system defaults here:
# PECUNATOR_BINANCE_API_KEY=your_api_key
# PECUNATOR_BINANCE_SECRET_KEY=your_secret_key

# --- Third-party Integrations ---
# API key for chart image generation
# CHART_IMG_API_KEY=your_chart_img_api_key

# --- Development & Testing ---
# Set to 1 to run the engine in STUB mode (exits without starting HTTP API)
# PECUNATOR_ENGINE_STUB=0
# Set to 1 to enable auto-reload on code changes (dev only)
# PECUNATOR_RELOAD=0
